rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    
    // Identity lookup helper (assuming users collection exists with roles)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Bidang
    match /bidang/{bidangId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || isOwner(userId);
    }

    // Projects
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.nama_paket is string && data.nama_paket.size() > 0 &&
               data.pagu is number && data.nilai_kontrak is number &&
               data.tahun_anggaran is number &&
               data.lokasi_kab_kota is string &&
               data.bidang_id is string;
      }

      allow read: if isSignedIn();
      allow create: if (hasRole('admin') || hasRole('operator')) && isValidProject(incoming());
      allow update: if (hasRole('admin') || hasRole('operator') || hasRole('kabid')) && isValidProject(incoming());
      allow delete: if hasRole('admin');

      // Nested Updates
      match /updates/{updateId} {
        function isValidUpdate(data) {
          return data.project_id is string &&
                 data.fisik_kumulatif is number &&
                 data.keuangan_nominal is number &&
                 data.termin_ke is number;
        }

        allow read: if isSignedIn();
        allow create: if (hasRole('admin') || hasRole('operator')) && isValidUpdate(incoming());
        allow update: if (hasRole('admin') || hasRole('kabid')) && isValidUpdate(incoming());
        allow delete: if hasRole('admin');

        // Nested Photos
        match /photos/{photoId} {
           allow read: if isSignedIn();
           allow write: if hasRole('admin') || hasRole('operator');
        }
      }
    }
  }
}
